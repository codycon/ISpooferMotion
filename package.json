{
  "name": "ispoofermotion",
  "version": "1.3.0",
  "main": "src/main/app.js",
  "description": "Animation spoofing utility for Roblox",
  "author": {
    "name": "IncredibroXP",
    "email": "incredibroxpdev@gmail.com"
  },
  "license": "GPL-3.0-or-later",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:plugin": "node scripts/build-plugin-rbxmx.js",
    "clean": "node scripts/clean.js",
    "build:all": "node scripts/build-all.js",
    "release:local-check": "node scripts/release-local-check.js",
    "dev": "electron . --dev",
    "test": "node scripts/run-private-tests.js tests/unit/*.test.js",
    "test:unit": "node scripts/run-private-tests.js tests/unit/*.test.js",
    "release:virustotal": "node scripts/upload-virustotal-release-assets.js",
    "release:hardening-check": "node scripts/release-hardening-check.js",
    "release:verify-assets": "node scripts/verify-release-assets.js",
    "release:check": "npm test && npm run release:local-check && node scripts/release-hardening-check.js --allow-generated-output",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "keytar": "^7.9.0"
  },
  "build": {
    "appId": "com.github.IncrediDev.ISpooferMotion",
    "productName": "ISpooferMotion",
    "files": [
      "src/**/*",
      "build/**/*",
      "package.json",
      "!**/.git/**/*",
      "!**/node_modules/.cache/**/*",
      "!launcher/**/*",
      "!downloads/**/*",
      "!dist/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "portable"
      ],
      "icon": "src/assets/app_icon.ico",
      "signAndEditExecutable": true,
      "legalTrademarks": "ISpooferMotion"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "src/assets/app_icon.png",
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "src/assets/app_icon.png",
      "category": "Utility"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "artifactName": "ISpooferMotion-App-${version}-${os}-${arch}.${ext}",
    "forceCodeSigning": false
  }
}
