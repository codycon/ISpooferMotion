{
  "name": "ispoofermotion",
  "version": "1.3.17",
  "main": "dist-main/app.js",
  "description": "Animation spoofing utility for Roblox",
  "author": {
    "name": "IncredibroXP",
    "email": "incredibroxpdev@gmail.com"
  },
  "license": "GPL-3.0-or-later",
  "scripts": {
    "start": "npm run build:main && electron .",
    "dev": "npm run build:main && electron . --dev",
    "test": "node --test",
    "build:main": "node scripts/build-main.js",
    "build:renderer": "node scripts/build-renderer.js",
    "build": "npm run build:main && npm run build:renderer && electron-builder",
    "build:plugin": "node scripts/build-plugin-rbxmx.js",
    "build:all": "node scripts/build-all.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release:virustotal": "node scripts/upload-virustotal-release-assets.js",
    "release:verify-assets": "node scripts/verify-release-assets.js",
    "postinstall": "electron-builder install-app-deps",
    "ci:install": "node scripts/ci-install.js",
    "rebuild:native": "electron-builder install-app-deps",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.8.3",
    "strip-comments": "^2.0.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "keytar": "^7.9.0",
    "luaparse": "^0.3.1"
  },
  "build": {
    "appId": "com.github.IncrediDev.ISpooferMotion",
    "productName": "ISpooferMotion",
    "files": [
      "src/**/*",
      "build/**/*",
      "package.json",
      "!**/.git/**/*",
      "!**/node_modules/.cache/**/*",
      "!src/renderer-react/node_modules/**/*",
      "!src/renderer-react/src/**/*",
      "!downloads/**/*",
      "!tests/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "src/assets/app_icon.ico",
      "signAndEditExecutable": true,
      "legalTrademarks": "ISpooferMotion",
      "azureSignOptions": {
        "publisherName": "ispoofermotion.com",
        "endpoint": "https://weu.codesigning.azure.net/",
        "codeSigningAccountName": "IncrediDev",
        "certificateProfileName": "ispoofermotion-cert"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ISpooferMotion",
      "deleteAppDataOnUninstall": true,
      "installerIcon": "src/assets/app_icon.ico",
      "uninstallerIcon": "src/assets/app_icon.ico",
      "installerSidebar": "src/assets/installer_sidebar.bmp",
      "uninstallerSidebar": "src/assets/installer_sidebar.bmp",
      "installerHeader": "src/assets/installer_header.bmp",
      "uninstallDisplayName": "ISpooferMotion",
      "displayLanguageSelector": false
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "src/assets/app_icon.png",
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "src/assets/app_icon.png",
      "category": "Utility"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "artifactName": "ISpooferMotion-App-${version}-${os}-${arch}.${ext}",
    "forceCodeSigning": false,
    "asarUnpack": [
      "src/assets/**/*"
    ]
  }
}
