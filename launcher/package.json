{
  "name": "ispoofermotion-launcher",
  "version": "1.3.10-hotfix.1",
  "description": "Electron launcher/updater for ISpooferMotion official releases.",
  "main": "src/main/main.js",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "start": "electron .",
    "test": "node ../scripts/run-private-tests.js specs/unit/*.test.js",
    "clean": "node scripts/clean.js",
    "build:win": "node scripts/build-win.js",
    "build:win:release": "node scripts/build-win.js --release",
    "build:setup": "node scripts/build-win.js",
    "dev": "electron . --dev"
  },
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.github.IncrediDev.ISpooferMotion.Launcher",
    "productName": "ISpooferLauncher",
    "artifactName": "ISpooferMotion-Setup.exe",
    "files": [
      "src/**/*",
      "package.json",
      "scripts/build-win.js",
      "!**/.git/**/*",
      "!**/node_modules/.cache/**/*",
      "!dist/**/*",
      "!out/**/*",
      "!build/**/*",
      "!*.log"
    ],
    "directories": {
      "output": "dist"
    },
    "afterPack": "scripts/after-pack.js",
    "win": {
      "target": "nsis",
      "icon": "src/assets/app_icon.ico",
      "signAndEditExecutable": false,
      "legalTrademarks": "ISpooferMotion"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ISpooferLauncher",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "src/assets/app_icon.ico",
      "uninstallerIcon": "src/assets/app_icon.ico",
      "installerHeaderIcon": "src/assets/app_icon.ico"
    },
    "forceCodeSigning": false,
    "nodeGypRebuild": false,
    "icon": "src/assets/app_icon.ico",
    "extraResources": [
      {
        "from": "src/assets/app_icon.ico",
        "to": "app_icon.ico"
      },
      {
        "from": "../CHANGELOG.md",
        "to": "CHANGELOG.md"
      }
    ]
  },
  "author": "IncrediDev and contributors",
  "productName": "ISpooferLauncher"
}
